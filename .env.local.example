# Copy this file to .env.local and fill in your values before running Docker Compose.
#   cp .env.local.example .env.local
#
# Usage:
#   docker compose --env-file .env.local up -d
#
# For Terraform acceptance tests, source this file first:
#   source .env.local && make testacc

# ---------------------------------------------------------------------------
# Bitbucket Data Center license key (required for automated setup).
# Without this, complete setup manually through the web UI at http://localhost:7990.
#
# Get a free timebomb developer license (30-day, auto-renews for dev):
#   https://developer.atlassian.com/platform/marketplace/timebomb-licenses-for-testing-server-apps/
# Or a free 30-day evaluation license:
#   https://www.atlassian.com/software/bitbucket/enterprise/data-center
# ---------------------------------------------------------------------------
BITBUCKET_LICENSE=

# Admin account password used during automated Docker setup.
# Must match BITBUCKET_PASSWORD below.
BITBUCKET_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Terraform provider environment variables.
# These are read by the provider when the corresponding HCL attributes are omitted.
# ---------------------------------------------------------------------------
export BITBUCKET_BASE_URL=http://localhost:7990
export BITBUCKET_USERNAME=admin
export BITBUCKET_PASSWORD=admin

# Set to true to skip TLS verification (useful for self-signed certs)
# export BITBUCKET_INSECURE_SKIP_VERIFY=true
